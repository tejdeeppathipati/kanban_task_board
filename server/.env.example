# Go Backend — Environment Variables
#
# Copy this file to .env and fill in the values before running the server.
# Never commit the .env file or any secrets to version control.

# Supabase database connection string (Postgres).
# Find this in Supabase Dashboard > Settings > Database > Connection String (URI).
# Use the "Session mode" connection string for transaction-pooled connections.
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase JWT secret used to verify access tokens.
# Find this in Supabase Dashboard > Settings > API > JWT Secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Port the Go API server listens on (default: 8080).
PORT=8080

# Comma-separated list of allowed CORS origins (default: http://localhost:5173).
ALLOWED_ORIGINS=http://localhost:5173
